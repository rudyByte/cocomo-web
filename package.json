{
  "name": "cocomo",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:push": "turbo db:push",
    "db:generate": "turbo db:generate",
    "format": "prettier --write \"**/*.{ts,tsx,md,css,json}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.5.4",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}

